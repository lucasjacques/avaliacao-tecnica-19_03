  "item": [
    {
      "name": "BrasilAPI - GET",
      "item": [
        {
          "name": "GET - Retrieve Address by CEP - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response should have Content-Type header\", function () {\r",
                  "    pm.expect(pm.response.headers.has(\"Content-Type\")).to.be.true;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Content-Type should be application/json\", function () {\r",
                  "    const contentType = pm.response.headers.get(\"Content-Type\");\r",
                  "    pm.expect(contentType).to.include(\"application/json\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Response has required fields\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData).to.have.property(\"cep\");\r",
                  "    pm.expect(jsonData).to.have.property(\"city\");\r",
                  "    pm.expect(jsonData).to.have.property(\"state\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"CEP is valid\", function () {\r",
                  "    const jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.cep).to.eql(\"88010400\");\r",
                  "}); "
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://brasilapi.com.br/api/cep/v1/88010400",
              "protocol": "https",
              "host": [
                "brasilapi",
                "com",
                "br"
              ],
              "path": [
                "api",
                "cep",
                "v1",
                "88010400"
              ]
            }
          },
          "response": []
        },
